server {
    listen 0.0.0.0:8080; 
    listen 8081;
    listen 0.0.0.0;

    server_name localhost mysite.com;

    root ./webPageFile/localhost;
    index index.html index.htm;

    autoindex off;

	#Commentaire ne pas lire
    client_max_body_size 1024;

    error_page 404 ./webPageFile/errors/404.html;
    error_page 500 ./webPageFile/errors/500.html;

    #return 302 https://profile.intra.42.fr/;

		location / {
        index index.html;
    }

    location /images {

        root ./webPageFile;

		#Commentaire ne pas lire
		
        autoindex on;

    }

    location /images/cat {

        root ./webPageFile;
        index index.html;
        autoindex on;

    }

    location /images/dog {

        root ./webPageFile;
        autoindex on;

    }

    location /upload
    {
        allowed_methods GET POST;
        client_max_body_size 5000000;
    }

    location /admin
    {
        return 403 "Forbidden";
    }

    location /google {
        return 301 https://www.google.com/;
    }

    location /wikipedia
    {
        return 301 https://fr.wikipedia.org/wiki/Xavier_Niel;
    }

    location /youtube
    {
        return 302 https://www.google.com/url?sa=t&source=web&rct=j&opi=89978449&url=https://www.youtube.com/watch%3Fv%3DdQw4w9WgXcQ;
    }
}


server {
    listen 0.0.0.0:9090;

    server_name test.com;

    root ./webPageFile/test.com;

    index index.html;

    autoindex on;

    error_page 404 /404.html;

    location / {
        allowed_methods GET;
    }
    
    location /delete {
        allowed_methods DELETE;
        return 200 "Delete OK";
    }
}

