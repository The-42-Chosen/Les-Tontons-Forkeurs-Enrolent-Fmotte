server {
    listen 0.0.0.0:8080; 
    listen 8081;
    listen 0.0.0.0;

    server_name localhost mysite.com;

    root /var/www/html;
    index index.html index.htm;

    autoindex off;

	#Commentaire ne pas lire
    client_max_body_size 1000000;

    error_page 404 /errors/404.html;
    error_page 500 /errors/500.html;

    #return 301 http://example.com;

		#location / {
        #index index.html;
    #}

    location /images {

        root /var/www/assets;

		#Commentaire ne pas lire
		
        autoindex on;

    }

    location /images/cat {

        root /var/www/assets;	
        autoindex on;

    }

    location /images/dog {

        root /var/www/assets;
        autoindex on;

    }

    location /upload
    {
        allowed_methods GET POST;
        client_max_body_size 5000000;
    }

    location /admin
    {
        return 403 "Forbidden";
    }

    location /errors {
        root /var/www/errors;
    }
}


server {
    listen 0.0.0.0:9090;

    server_name test.com;

    root /var/www/test;

    index index.html;

    autoindex on;

    error_page 404 /404.html;

    location / {
        allowed_methods GET;
    }
    
    location /delete {
        allowed_methods DELETE;
        return 200 "Delete OK";
    }
}

server {
    listen 8081;
