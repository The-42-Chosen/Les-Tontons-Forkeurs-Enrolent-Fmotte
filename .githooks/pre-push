#!/bin/sh

set -eu

REMOTE_NAME="$1"

if command -v clang-format-12 >/dev/null 2>&1; then
    CLANG_FORMAT="clang-format-12"
elif command -v clang-format >/dev/null 2>&1; then
    CLANG_FORMAT="clang-format"
else
    echo "pre-push: clang-format-12 (or clang-format) not found." >&2
    exit 1
fi

TMP_LIST="$(mktemp)"
TMP_REFS="$(mktemp)"
cleanup() {
    rm -f "$TMP_LIST" "$TMP_REFS"
}
trap cleanup EXIT INT TERM

cat > "$TMP_REFS"

git ls-files -- '*.hpp' '*.cpp' '*.h' '*.c' > "$TMP_LIST"
if [ ! -s "$TMP_LIST" ]; then
    exit 0
fi

while IFS= read -r file; do
    "$CLANG_FORMAT" -i --style=microsoft "$file"
done < "$TMP_LIST"

if git diff --quiet -- '*.hpp' '*.cpp' '*.h' '*.c'; then
    exit 0
fi

git add -- '*.hpp' '*.cpp' '*.h' '*.c'

if git diff --cached --quiet -- '*.hpp' '*.cpp' '*.h' '*.c'; then
    exit 0
fi

git commit -m "(hook): Clang-format applied" --no-verify

set --
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    if [ -z "$local_ref" ]; then
        continue
    fi

    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        set -- "$@" ":$remote_ref"
    else
        set -- "$@" "$local_ref:$remote_ref"
    fi
done < "$TMP_REFS"

if [ "$#" -eq 0 ]; then
    exit 0
fi

exec git push --no-verify "$REMOTE_NAME" "$@"